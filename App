<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Siren Flow - Underwater Knowledge</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300;500;700&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet">
    <style>
        :root {
            --ocean-deep: #001219;
            --ocean-mid: #005f73;
            --ocean-light: #0a9396;
            --siren-glow: #94d2bd;
            --coral-accent: #ee9b00;
        }

        body {
            background: linear-gradient(180deg, #002129 0%, #001219 100%);
            color: #e9ecef;
            font-family: 'Quicksand', sans-serif;
            min-height: 100vh;
            overflow-x: hidden;
            margin: 0;
        }

        /* Animated Bubbles */
        .bubble {
            position: absolute;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 50%;
            bottom: -100px;
            animation: rise 15s infinite ease-in;
            z-index: 0;
        }

        @keyframes rise {
            0% { transform: translateY(0) scale(1); opacity: 0; }
            50% { opacity: 0.3; }
            100% { transform: translateY(-120vh) scale(1.5); opacity: 0; }
        }

        /* Custom UI Styling */
        .glass-panel {
            background: rgba(0, 95, 115, 0.15);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(148, 210, 189, 0.2);
            border-radius: 24px;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
        }

        .siren-title {
            font-family: 'Playfair Display', serif;
            background: linear-gradient(to right, #94d2bd, #0a9396);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            filter: drop-shadow(0 0 8px rgba(148, 210, 189, 0.4));
        }

        .search-input {
            background: rgba(255, 255, 255, 0.05);
            border: 2px solid var(--ocean-mid);
            transition: all 0.3s ease;
        }

        .search-input:focus {
            outline: none;
            border-color: var(--siren-glow);
            box-shadow: 0 0 15px rgba(148, 210, 189, 0.3);
            background: rgba(255, 255, 255, 0.1);
        }

        .result-card {
            animation: slideUp 0.6s cubic-bezier(0.23, 1, 0.32, 1);
        }

        @keyframes slideUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .ocean-button {
            background: var(--ocean-mid);
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .ocean-button:hover {
            background: var(--ocean-light);
            transform: translateY(-2px);
        }

        .source-tag {
            background: rgba(238, 155, 0, 0.2);
            border: 1px solid var(--coral-accent);
            color: var(--coral-accent);
        }

        .loading-wave {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 5px;
        }

        .loading-wave div {
            width: 8px;
            height: 24px;
            background: var(--siren-glow);
            animation: wave 1.2s infinite ease-in-out;
        }

        @keyframes wave {
            0%, 40%, 100% { transform: scaleY(0.4); }
            20% { transform: scaleY(1); }
        }
    </style>
</head>
<body class="relative flex flex-col items-center p-4 md:p-8">

    <!-- Background Elements -->
    <div id="bubble-container"></div>

    <!-- Header Section -->
    <header class="z-10 text-center mb-12">
        <h1 class="text-6xl md:text-8xl siren-title font-bold mb-2">Siren Flow</h1>
        <p class="text-ocean-light tracking-widest uppercase text-sm font-medium">Oceanic Intelligence Repository</p>
    </header>

    <!-- Search Section -->
    <main class="z-10 w-full max-w-3xl">
        <div class="glass-panel p-6 mb-8">
            <form id="searchForm" class="flex flex-col md:flex-row gap-4">
                <input 
                    type="text" 
                    id="searchInput" 
                    placeholder="Ask about the abyss (e.g., Colossal Squid, Mariana Trench)..." 
                    class="search-input flex-grow px-6 py-4 rounded-xl text-white placeholder-slate-500"
                    required
                >
                <button type="submit" class="ocean-button px-8 py-4 rounded-xl font-bold flex items-center justify-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    Explore
                </button>
            </form>
        </div>

        <!-- Results Area -->
        <div id="loading" class="hidden py-12">
            <div class="loading-wave">
                <div style="animation-delay: -1.1s"></div>
                <div style="animation-delay: -1.0s"></div>
                <div style="animation-delay: -0.9s"></div>
            </div>
            <p class="text-center mt-4 text-siren-glow animate-pulse">Diving into the depths...</p>
        </div>

        <div id="results" class="space-y-6">
            <!-- Initial State -->
            <div class="text-center py-20 opacity-40">
                <svg class="mx-auto mb-4" xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10H12V2Z"/><path d="M12 12 2.1 11.9A10 10 0 0 0 12 22V12Z"/><path d="M12 12V2a10 10 0 0 1 10 10H12Z"/></svg>
                <p>Enter an underwater topic to begin your descent</p>
            </div>
        </div>
    </main>

    <footer class="z-10 mt-auto pt-12 pb-4 text-slate-500 text-xs text-center">
        Powered by DuckDuckGo Instant Answer API • Siren Flow © 2024
    </footer>

    <script>
        // Background Bubbles Generation
        const bubbleContainer = document.getElementById('bubble-container');
        for(let i = 0; i < 20; i++) {
            const bubble = document.createElement('div');
            bubble.className = 'bubble';
            const size = Math.random() * 40 + 10 + 'px';
            bubble.style.width = size;
            bubble.style.height = size;
            bubble.style.left = Math.random() * 100 + '%';
            bubble.style.animationDelay = Math.random() * 10 + 's';
            bubble.style.animationDuration = Math.random() * 10 + 10 + 's';
            bubbleContainer.appendChild(bubble);
        }

        const searchForm = document.getElementById('searchForm');
        const searchInput = document.getElementById('searchInput');
        const resultsDiv = document.getElementById('results');
        const loadingDiv = document.getElementById('loading');

        searchForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const query = searchInput.value.trim();
            if (!query) return;

            // UI Transitions
            resultsDiv.innerHTML = '';
            loadingDiv.classList.remove('hidden');

            try {
                const response = await fetch(`https://api.duckduckgo.com/?q=${encodeURIComponent(query)}&format=json&pretty=1&no_html=1&skip_disambig=1`);
                const data = await response.json();
                
                displayResults(data, query);
            } catch (error) {
                console.error('Fetch Error:', error);
                resultsDiv.innerHTML = `
                    <div class="glass-panel p-8 text-center border-red-500/50">
                        <p class="text-red-400">The current is too strong. We couldn't reach the depths. Please try again.</p>
                    </div>
                `;
            } finally {
                loadingDiv.classList.add('hidden');
            }
        });

        function displayResults(data, query) {
            if (!data.Abstract && data.RelatedTopics.length === 0) {
                resultsDiv.innerHTML = `
                    <div class="glass-panel p-8 text-center">
                        <p class="text-lg">No pearls found for "${query}". Try a broader term like "Shark" or "Coral".</p>
                    </div>
                `;
                return;
            }

            let html = '';

            // Main Answer (Abstract)
            if (data.Abstract) {
                html += `
                    <div class="result-card glass-panel p-8">
                        <div class="flex items-center gap-3 mb-4">
                            <span class="px-3 py-1 text-xs font-bold uppercase tracking-widest source-tag rounded-full">Knowledge Pearl</span>
                        </div>
                        <h2 class="text-3xl font-bold mb-4 text-siren-glow">${data.Heading || query}</h2>
                        <p class="text-lg leading-relaxed text-slate-200 mb-6">${data.Abstract}</p>
                        
                        ${data.Image ? `
                            <div class="mb-6 rounded-xl overflow-hidden border border-ocean-mid">
                                <img src="${data.Image}" alt="${data.Heading}" class="w-full object-cover max-h-64" onerror="this.style.display='none'">
                            </div>
                        ` : ''}

                        <div class="pt-6 border-t border-white/10 flex flex-wrap justify-between items-center gap-4">
                            <div class="flex items-center gap-2">
                                <span class="text-slate-500 text-sm">Source:</span>
                                <a href="${data.AbstractURL}" target="_blank" class="text-ocean-light hover:text-siren-glow font-medium flex items-center gap-1 transition-colors">
                                    ${data.AbstractSource || 'View Original Source'}
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
                                </a>
                            </div>
                        </div>
                    </div>
                `;
            }

            // Related Topics
            if (data.RelatedTopics && data.RelatedTopics.length > 0) {
                const topics = data.RelatedTopics.filter(t => t.Text).slice(0, 4);
                if (topics.length > 0) {
                    html += `<div class="grid grid-cols-1 md:grid-cols-2 gap-4">`;
                    topics.forEach(topic => {
                        html += `
                            <div class="result-card glass-panel p-5 hover:bg-white/5 transition-colors cursor-default">
                                <p class="text-sm text-slate-300 line-clamp-3">${topic.Text}</p>
                                <a href="${topic.FirstURL}" target="_blank" class="inline-block mt-3 text-xs text-siren-glow font-bold uppercase tracking-wider hover:underline">Dive Deeper</a>
                            </div>
                        `;
                    });
                    html += `</div>`;
                }
            }

            resultsDiv.innerHTML = html;
        }
    </script>
</body>
</html>
